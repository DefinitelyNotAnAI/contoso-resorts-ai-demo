# Contoso Resorts AI — Environment Configuration
# Copy this file to .env and fill in your Azure resource values.

# --- SQL Database (Fabric SQL or Azure SQL — same pyodbc connection) ---
# Fabric SQL:  <workspace-guid>.datawarehouse.fabric.microsoft.com
# Azure SQL:   <server>.database.windows.net
SQL_SERVER=
SQL_DATABASE=

# --- Azure AI Foundry ---
# Set to the endpoint of your Azure OpenAI resource (provisioned by azd)
AI_FOUNDRY_ENDPOINT=https://<YOUR_OPENAI_RESOURCE>.openai.azure.com
AI_FOUNDRY_MODEL=gpt-4o-mini

# --- Azure OpenAI Realtime (GPT Realtime — separate resource, eastus2) ---
# A dedicated Azure OpenAI resource is required for GlobalStandard SKU (not available in eastus)
REALTIME_ENDPOINT=https://<YOUR_REALTIME_OPENAI_RESOURCE>.openai.azure.com
REALTIME_MODEL=gpt-4o-realtime-preview
REALTIME_API_VERSION=2024-10-01-preview

# --- Azure Content Safety ---
CONTENT_SAFETY_ENDPOINT=https://<YOUR_RESOURCE>.cognitiveservices.azure.com

# --- Fabric Data Agent (optional — ADR-006 feature flag) ---
# Set USE_DATA_AGENT=true to use the Fabric Data Agent as primary query path.
# When false (default), GPT-writes-SQL is used instead.
USE_DATA_AGENT=false
DATA_AGENT_URL=https://<YOUR_FABRIC_WORKSPACE>.datawarehouse.fabric.microsoft.com
DATA_AGENT_ID=

# --- Fabric Capacity ---
# Used by CRM UI resume/suspend controls and postprovision scripts
FABRIC_CAPACITY_SUBSCRIPTION_ID=
FABRIC_CAPACITY_RESOURCE_GROUP=
FABRIC_CAPACITY_NAME=

# --- Azure AD (usually not needed — DefaultAzureCredential handles this) ---
# AZURE_TENANT_ID=<YOUR_TENANT_ID>
